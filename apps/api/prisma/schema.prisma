generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EMPLOYER
  CANDIDATE
  RECRUITER
}

enum RecruiterRole {
  OWNER
  ADMIN
  RECRUITER
  HIRING_MANAGER
  HR_EXECUTIVE
  INTERVIEWER
  READ_ONLY
}

enum RecruiterStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum OAuthProvider {
  GOOGLE
  LINKEDIN
}

enum CompanyStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum RemotePolicy {
  ONSITE
  HYBRID
  REMOTE
}

enum ApplicationStatus {
  SUBMITTED
  REVIEWING
  SHORTLISTED
  INTERVIEW_SCHEDULED
  REJECTED
  WITHDRAWN
  OFFERED
  HIRED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum NotificationType {
  APPLICATION_SUBMITTED
  APPLICATION_WITHDRAWN
  INTERVIEW_SCHEDULED
  JOB_CLOSED
  PROFILE_UPDATED
  APPLICATION_STATUS
  RECRUITER_ALERT
  STATUS_CHANGE_NOTIFICATION
  FOLLOW_UP_EMAIL
  INTERVIEW_REMINDER
}

enum HiringStageType {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  HIRED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AutomationEventType {
  RESUME_PROCESSING
  APPLICATION_PROCESSING
  INTERVIEW_REMINDER
  FOLLOW_UP_EMAIL
  STATUS_CHANGE_NOTIFICATION
  CANDIDATE_MATCHING
  RECRUITER_ALERT
}

enum AutomationRunStatus {
  QUEUED
  SUCCEEDED
  FAILED
  SKIPPED
}

enum AiArtifactType {
  RESUME_ANALYSIS
  RESUME_SCORE
  CANDIDATE_MATCH
  SKILL_GAP
  JOB_DESCRIPTION
  INTERVIEW_QUESTIONS
  CANDIDATE_SUMMARY
  HIRING_ASSISTANT
}

enum EmailTemplateType {
  INTERVIEW_INVITATION
  OFFER_EMAIL
  REJECTION_EMAIL
  FOLLOW_UP
  REMINDER
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum BillingSubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum LeadStatus {
  NEW
  QUALIFIED
  NURTURING
  WON
  LOST
}

enum SalesStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum CrmActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
  STATUS_CHANGE
}

enum MediaAssetType {
  RESUME
  PROFILE_IMAGE
  COMPANY_LOGO
  DOCUMENT
  CERTIFICATE
  CONTENT_IMAGE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CommunicationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum DeliveryStatus {
  QUEUED
  SENT
  FAILED
  DELIVERED
  READ
}

enum ExportStatus {
  QUEUED
  READY
  FAILED
}

enum SystemSettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum FeatureFlagEnvironment {
  GLOBAL
  DEVELOPMENT
  STAGING
  PRODUCTION
}

model User {
  id                   String                    @id @default(uuid()) @db.Uuid
  email                String                    @unique
  passwordHash         String?
  role                 UserRole                  @default(CANDIDATE)
  status               UserStatus                @default(PENDING_VERIFICATION)
  emailVerifiedAt      DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  profile              Profile?
  sessions             Session[]
  oauthAccounts        OAuthAccount[]
  passwordResetTokens  PasswordResetToken[]
  verificationTokens   EmailVerificationToken[]
  auditLogs            AuditLog[]                @relation("AuditActor")
  ownedCompanies       Company[]                 @relation("CompanyOwner")
  createdJobs          Job[]                     @relation("JobCreator")
  candidateProfile     CandidateProfile?
  applications         JobApplication[]          @relation("CandidateApplications")
  scheduledInterviews  Interview[]               @relation("InterviewScheduler")
  notifications        Notification[]
  assignedJobs         Job[]                     @relation("AssignedRecruiterJobs")
  assignedCandidates   CandidateProfile[]        @relation("AssignedRecruiterCandidates")
  recruiterAssignments RecruiterAssignment[]     @relation("RecruiterAssignments")
  savedSearches        SavedSearch[]             @relation("RecruiterSavedSearches")
  recruiterTasks       RecruiterTask[]           @relation("RecruiterTasks")
  authoredNotes        CandidateNote[]           @relation("CandidateNoteAuthor")
  candidateRatings     CandidateRating[]         @relation("CandidateRatingRecruiter")
  tagAssignments       CandidateProfileTag[]     @relation("CandidateTagAssignedBy")
  stageChanges         ApplicationStageHistory[] @relation("ApplicationStageChanger")
  aiArtifacts          AiArtifact[]              @relation("AiArtifactUser")
  automationRuns       AutomationRun[]           @relation("AutomationRunActor")
  emailTemplates       EmailTemplate[]           @relation("EmailTemplateCreator")
  roleAssignments      PlatformRoleAssignment[]
  uploadedMedia        MediaAsset[]              @relation("MediaUploadedBy")
  ownedLeads           CrmLead[]                 @relation("LeadOwner")
  ownedClients         CrmClient[]               @relation("ClientOwner")
  ownedOpportunities   SalesOpportunity[]        @relation("OpportunityOwner")
  crmTasks             CrmTask[]                 @relation("CrmTaskOwner")
  crmNotes             CrmNote[]                 @relation("CrmNoteAuthor")
  crmActivities        CrmActivity[]             @relation("CrmActivityActor")
  analyticsReports          AnalyticsReport[]         @relation("ReportCreator")
  csvExports                CsvExport[]               @relation("ExportCreator")
  contentPages              ContentPage[]             @relation("ContentAuthor")
  recruiterProfile          RecruiterProfile?
  ownedHiringTeams          HiringTeam[]              @relation("HiringTeamOwner")
  sentHiringTeamInvitations HiringTeamInvitation[]    @relation("HiringTeamInviter")
  hiringTeamMemberships     HiringTeamMember[]
  vendorMembers             VendorMember[]
  requisitions              JobRequisition[]          @relation("HiringManagerRequisitions")
  commissions               RecruiterCommission[]     @relation("RecruiterCommissions")
  copilotSessions           CopilotSession[]          @relation("UserCopilotSessions")
  mobileDevices             MobileDevice[]            @relation("UserMobileDevices")
  developerAccount          DeveloperAccount?         @relation("UserDeveloperAccount")
  employeeProfile           EmployeeProfile?          @relation("UserEmployeeProfile")

  @@map("users")
}

model Profile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @db.Uuid
  firstName   String
  lastName    String
  headline    String?
  companyName String?
  phone       String?
  country     String?
  city        String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model OAuthAccount {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @db.Uuid
  provider          OAuthProvider
  providerAccountId String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @db.Uuid
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Company {
  id                 String                @id @default(uuid()) @db.Uuid
  ownerId            String                @db.Uuid
  name               String
  slug               String                @unique
  status             CompanyStatus         @default(DRAFT)
  logoUrl            String?
  logoKey            String?
  bannerUrl          String?
  bannerKey          String?
  website            String?
  industry           String?
  size               String?
  headquarters       String?
  description        String?
  twitterUrl         String?
  linkedinUrl        String?
  facebookUrl        String?
  verificationStatus String                @default("UNVERIFIED")
  isVerified         Boolean               @default(false)
  settings           Json?
  billingCustomerId  String?
  subscriptionPlan   String?
  subscriptionStatus String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  owner              User                  @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  jobs               Job[]
  savedCandidates    SavedCandidate[]
  crmClients         CrmClient[]
  mediaAssets        MediaAsset[]
  subscriptions      BillingSubscription[]
  invoices           Invoice[]
  payments           Payment[]
  recruiters         RecruiterProfile[]
  hiringTeams        HiringTeam[]
  verifications      CompanyVerification[]
  requisitions       JobRequisition[]
  placements         Placement[]           @relation("CompanyPlacements")
  clientInvoices     ClientInvoice[]       @relation("CompanyInvoices")
  appInstallations   AppInstallation[]     @relation("CompanyAppInstallations")
  resourceQuotas     ResourceQuota[]       @relation("CompanyResourceQuotas")
  tenantLifecycleLogs TenantLifecycleLog[]  @relation("CompanyTenantLogs")
  supportTickets     SupportTicket[]       @relation("CompanyTickets")
  healthScores       CustomerHealthScore[] @relation("CompanyHealthScores")
  whiteLabelConfig   WhiteLabelConfig?     @relation("CompanyWhiteLabel")

  @@index([ownerId])
  @@index([status])
  @@map("companies")
}

model Job {
  id                   String                @id @default(uuid()) @db.Uuid
  companyId            String                @db.Uuid
  createdById          String                @db.Uuid
  assignedRecruiterId  String?               @db.Uuid
  title                String
  slug                 String
  summary              String
  description          String
  responsibilities     String?
  requirements         String?
  benefits             String?
  category             String
  location             String
  country              String?
  salaryMin            Int?
  salaryMax            Int?
  salaryCurrency       String                @default("USD")
  employmentType       EmploymentType
  experienceLevel      ExperienceLevel
  remotePolicy         RemotePolicy
  status               JobStatus             @default(DRAFT)
  featured             Boolean               @default(false)
  publishedAt          DateTime?
  closedAt             DateTime?
  applicationDeadline  DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy            User                  @relation("JobCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignedRecruiter    User?                 @relation("AssignedRecruiterJobs", fields: [assignedRecruiterId], references: [id], onDelete: SetNull)
  applications         JobApplication[]
  savedJobs            SavedJob[]
  analytics            JobAnalytics?
  recruiterAssignments RecruiterAssignment[]
  tasks                RecruiterTask[]       @relation("JobTaskTarget")
  candidateRatings     CandidateRating[]
  hiringStages         HiringStage[]
  aiArtifacts          AiArtifact[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([status])
  @@index([assignedRecruiterId])
  @@index([category])
  @@index([location])
  @@index([employmentType])
  @@index([experienceLevel])
  @@index([remotePolicy])
  @@index([featured])
  @@index([createdAt])
  @@map("jobs")
}

model JobAnalytics {
  id           String   @id @default(uuid()) @db.Uuid
  jobId        String   @unique @db.Uuid
  views        Int      @default(0)
  saves        Int      @default(0)
  applications Int      @default(0)
  shortlisted  Int      @default(0)
  rejected     Int      @default(0)
  interviews   Int      @default(0)
  updatedAt    DateTime @updatedAt
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_analytics")
}

model CandidateProfile {
  id                   String                   @id @default(uuid()) @db.Uuid
  userId               String                   @unique @db.Uuid
  assignedRecruiterId  String?                  @db.Uuid
  resumeUrl            String?
  resumeKey            String?
  resumeOriginalName   String?
  linkedinUrl          String?
  portfolioUrl         String?
  preferredLocation    String?
  salaryExpectationMin Int?
  salaryExpectationMax Int?
  salaryCurrency       String                   @default("USD")
  preferredJobType     EmploymentType?
  availability         String?
  completionScore      Int                      @default(0)
  headline             String?
  bio                  String?
  location             String?
  remotePreference     String?
  workAuthorization    String?
  currentEmployer      String?
  currentDesignation   String?
  currentSalary        Int?
  noticePeriod         String?
  yearsOfExperience    Int?
  phone                String?
  phoneVerified        Boolean                  @default(false)
  emailVerified        Boolean                  @default(false)
  isPublic             Boolean                  @default(true)
  shareWithSearch      Boolean                  @default(true)
  showSalary           Boolean                  @default(true)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  user                 User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedRecruiter    User?                    @relation("AssignedRecruiterCandidates", fields: [assignedRecruiterId], references: [id], onDelete: SetNull)
  education            CandidateEducation[]
  experience           CandidateExperience[]
  skills               CandidateSkill[]
  certifications       CandidateCertification[]
  languages            CandidateLanguage[]
  resumes              ResumeVersion[]
  savedJobs            SavedJob[]
  savedByCompanies     SavedCandidate[]
  recruiterAssignments RecruiterAssignment[]
  notes                CandidateNote[]
  ratings              CandidateRating[]
  tags                 CandidateProfileTag[]
  duplicateSources     CandidateDuplicate[]     @relation("PrimaryDuplicate")
  duplicateMatches     CandidateDuplicate[]     @relation("DuplicateCandidate")
  resumeIndex          ResumeIndex?
  tasks                RecruiterTask[]          @relation("CandidateTaskTarget")
  aiArtifacts          AiArtifact[]
  vendorSubmissions    VendorSubmission[]
  placements           Placement[]              @relation("CandidatePlacements")
  leaveRequests        LeaveRequest[]
  expenseClaims        ExpenseClaim[]
  complianceRecords    WorkerCompliance[]
 
  @@index([assignedRecruiterId])
  @@map("candidate_profiles")
}

model ResumeVersion {
  id                 String           @id @default(uuid()) @db.Uuid
  candidateProfileId String           @db.Uuid
  name               String           // e.g. "Primary Resume", "Tailored Resume"
  resumeUrl          String
  resumeKey          String
  resumeOriginalName String
  isPrimary          Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("resume_versions")
}

model CandidateEducation {
  id                 String           @id @default(uuid()) @db.Uuid
  candidateProfileId String           @db.Uuid
  institution        String
  degree             String
  fieldOfStudy       String?
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("candidate_education")
}

model CandidateExperience {
  id                 String           @id @default(uuid()) @db.Uuid
  candidateProfileId String           @db.Uuid
  company            String
  title              String
  location           String?
  startDate          DateTime?
  endDate            DateTime?
  current            Boolean          @default(false)
  description        String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("candidate_experience")
}

model CandidateSkill {
  id                 String           @id @default(uuid()) @db.Uuid
  candidateProfileId String           @db.Uuid
  name               String
  level              String?
  createdAt          DateTime         @default(now())
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@unique([candidateProfileId, name])
  @@map("candidate_skills")
}

model CandidateCertification {
  id                 String           @id @default(uuid()) @db.Uuid
  candidateProfileId String           @db.Uuid
  name               String
  issuer             String?
  issuedAt           DateTime?
  expiresAt          DateTime?
  credentialUrl      String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("candidate_certifications")
}

model CandidateLanguage {
  id                 String           @id @default(uuid()) @db.Uuid
  candidateProfileId String           @db.Uuid
  name               String
  proficiency        String
  createdAt          DateTime         @default(now())
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@unique([candidateProfileId, name])
  @@map("candidate_languages")
}

model SavedJob {
  id                 String           @id @default(uuid()) @db.Uuid
  candidateProfileId String           @db.Uuid
  jobId              String           @db.Uuid
  createdAt          DateTime         @default(now())
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  job                Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([candidateProfileId, jobId])
  @@index([jobId])
  @@map("saved_jobs")
}

model SavedCandidate {
  id                 String           @id @default(uuid()) @db.Uuid
  companyId          String           @db.Uuid
  candidateProfileId String           @db.Uuid
  notes              String?
  createdAt          DateTime         @default(now())
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@unique([companyId, candidateProfileId])
  @@index([candidateProfileId])
  @@map("saved_candidates")
}

model JobApplication {
  id             String                    @id @default(uuid()) @db.Uuid
  jobId          String                    @db.Uuid
  candidateId    String                    @db.Uuid
  currentStageId String?                   @db.Uuid
  status         ApplicationStatus         @default(SUBMITTED)
  coverLetter    String?
  resumeUrl      String?
  resumeKey      String?
  expectedSalary Int?
  availableFrom  DateTime?
  withdrawnAt    DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  job            Job                       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate      User                      @relation("CandidateApplications", fields: [candidateId], references: [id], onDelete: Cascade)
  currentStage   HiringStage?              @relation("ApplicationCurrentStage", fields: [currentStageId], references: [id], onDelete: SetNull)
  timeline       JobApplicationEvent[]
  interviews     Interview[]
  stageHistory   ApplicationStageHistory[]
  tasks          RecruiterTask[]           @relation("ApplicationTaskTarget")
  aiArtifacts    AiArtifact[]

  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
  @@index([currentStageId])
  @@index([status])
  @@map("job_applications")
}

model JobApplicationEvent {
  id            String            @id @default(uuid()) @db.Uuid
  applicationId String            @db.Uuid
  status        ApplicationStatus
  note          String?
  createdAt     DateTime          @default(now())
  application   JobApplication    @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("job_application_events")
}

model Interview {
  id            String          @id @default(uuid()) @db.Uuid
  applicationId String          @db.Uuid
  scheduledById String          @db.Uuid
  startsAt      DateTime
  endsAt        DateTime
  timezone      String          @default("UTC")
  location      String?
  meetingUrl    String?
  status        InterviewStatus @default(SCHEDULED)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  application   JobApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduledBy   User            @relation("InterviewScheduler", fields: [scheduledById], references: [id], onDelete: Restrict)

  @@index([applicationId])
  @@index([scheduledById])
  @@index([startsAt])
  @@map("interviews")
}

model Notification {
  id         String                 @id @default(uuid()) @db.Uuid
  userId     String                 @db.Uuid
  type       NotificationType
  title      String
  body       String
  metadata   Json?
  readAt     DateTime?
  createdAt  DateTime               @default(now())
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
  @@map("notifications")
}

model RecruiterAssignment {
  id                 String            @id @default(uuid()) @db.Uuid
  recruiterId        String            @db.Uuid
  jobId              String?           @db.Uuid
  candidateProfileId String?           @db.Uuid
  createdAt          DateTime          @default(now())
  recruiter          User              @relation("RecruiterAssignments", fields: [recruiterId], references: [id], onDelete: Cascade)
  job                Job?              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateProfile   CandidateProfile? @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([recruiterId])
  @@index([jobId])
  @@index([candidateProfileId])
  @@map("recruiter_assignments")
}

model SavedSearch {
  id          String   @id @default(uuid()) @db.Uuid
  recruiterId String   @db.Uuid
  name        String
  query       String?
  filters     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  recruiter   User     @relation("RecruiterSavedSearches", fields: [recruiterId], references: [id], onDelete: Cascade)

  @@index([recruiterId])
  @@map("saved_searches")
}

model RecruiterTask {
  id                        String            @id @default(uuid()) @db.Uuid
  recruiterId               String            @db.Uuid
  title                     String
  description               String?
  dueAt                     DateTime?
  status                    TaskStatus        @default(TODO)
  priority                  TaskPriority      @default(MEDIUM)
  relatedJobId              String?           @db.Uuid
  relatedCandidateProfileId String?           @db.Uuid
  relatedApplicationId      String?           @db.Uuid
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  recruiter                 User              @relation("RecruiterTasks", fields: [recruiterId], references: [id], onDelete: Cascade)
