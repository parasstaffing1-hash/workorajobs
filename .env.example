JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
PASSWORD_MIN_LENGTH=12
COOKIE_SECRET=replace-with-a-long-cookie-secret
CSRF_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GOOGLE_CLIENT_ID=
