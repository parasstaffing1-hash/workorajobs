NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# PostgreSQL Configuration (Support DATABASE_URL OR individual POSTGRES_* variables)
DATABASE_URL=postgresql://workora:workora_password@localhost:5432/workora_jobs?schema=public

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=workora_jobs
POSTGRES_USER=workora
POSTGRES_PASSWORD=workora_password
POSTGRES_SCHEMA=public
POSTGRES_CONNECTION_LIMIT=10
REDIS_URL=redis://redis:6379
JWT_SECRET=replace-with-at-least-32-characters-secure-random-jwt-secret
JWT_SECRET_PREVIOUS=optional-previous-jwt-secret-for-zero-downtime-rotation
JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
PASSWORD_MIN_LENGTH=12
COOKIE_SECRET=replace-with-a-long-cookie-secret
CSRF_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/oauth/google/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:4000/api/v1/auth/linkedin/callback

AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=
EMAIL_PROVIDER=log
EMAIL_FROM=Workora Jobs <no-reply@workorajobs.com>

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free
NEXT_PUBLIC_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
N8N_BASE_URL=
N8N_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000/billing?checkout=success
STRIPE_CANCEL_URL=http://localhost:3000/billing?checkout=cancel

SMS_PROVIDER=disabled
SMS_API_KEY=
WHATSAPP_PROVIDER=disabled
WHATSAPP_API_KEY=
PUSH_PROVIDER=disabled
PUSH_API_KEY=

CACHE_TTL_SECONDS=60
SENTRY_DSN=
LOG_LEVEL=info

# Heartbeat Monitoring (e.g. Dead Man's Snitch / Cronitor)
DEAD_MAN_SNITCH_URL=

