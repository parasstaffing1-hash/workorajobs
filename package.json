{
  "name": "workora-jobs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Workora interview preparation API",
  "scripts": {
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "dev:api": "pnpm --filter @workora/api start:dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",

    "start": "next start -p 3000 -H 0.0.0.0",
    "preview": "next start -p 3000 -H 0.0.0.0",
    "seed": "tsx prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/throttler": "^6.5.0",
    "@next/third-parties": "^16.2.10",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "autoprefixer": "^10.5.4",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.42.2",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.10",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfjs-dist": "^6.1.200",
    "pg": "^8.22.0",
    "postcss": "^8.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "xss": "^1.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@nestjs/testing": "^10.0.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/jest": "^29.5.14",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/supertest": "^7.2.1",
    "axe-core": "^4.12.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "jest": "^29.7.0",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.1",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
