NODE_ENV=production
NEXT_PUBLIC_API_URL=https://workorajobs.com/api/v1

POSTGRES_USER=workora
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=workora_jobs
POSTGRES_PORT=5432
REDIS_PORT=6379

API_PORT=4000
API_PREFIX=api/v1
APP_URL=https://workorajobs.com
API_URL=https://workorajobs.com
DATABASE_URL=postgresql://workora:replace-with-strong-postgres-password@postgres:5432/workora_jobs?schema=public
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
PASSWORD_MIN_LENGTH=12
COOKIE_SECRET=replace-with-long-random-cookie-secret
CSRF_ENABLED=true
CORS_ORIGINS=https://workorajobs.com,https://www.workorajobs.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://workorajobs.com/api/v1/auth/google/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=https://workorajobs.com/api/v1/auth/linkedin/callback

AWS_REGION=eu-north-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=
EMAIL_PROVIDER=log
EMAIL_FROM=Workora Jobs <no-reply@workorajobs.com>

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
N8N_BASE_URL=
N8N_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://workorajobs.com/billing?checkout=success
STRIPE_CANCEL_URL=https://workorajobs.com/billing?checkout=cancel

SMS_PROVIDER=disabled
SMS_API_KEY=
WHATSAPP_PROVIDER=disabled
WHATSAPP_API_KEY=
PUSH_PROVIDER=disabled
PUSH_API_KEY=

CACHE_TTL_SECONDS=60
SENTRY_DSN=
LOG_LEVEL=info
